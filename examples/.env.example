# browser-base configuration
#
# Copy this file to `.env` (or to `~/.browserbase.env`) and fill in the
# values you want. All variables are optional except `OPENAI_API_KEY`,
# which is required for any of the LLM-powered tools (act, observe,
# extract) to work with the default model.
#
# Variables are read by `resolveConfig()` and override the defaults
# baked into the library. Priority order:
#   1. Explicit options passed to `resolveConfig({ ... })`
#   2. Environment variables (this file)
#   3. Library defaults

# ----------------------------------------------------------------------------
# LLM credentials
# ----------------------------------------------------------------------------

# Required when using any OpenAI model. Stagehand picks this up
# automatically based on the model name's `openai/` prefix.
OPENAI_API_KEY=sk-your-openai-api-key-here

# If you switch the model to an Anthropic one, set this instead:
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ----------------------------------------------------------------------------
# Model
# ----------------------------------------------------------------------------

# Model used by `act`, `observe`, and `extract`.
# Format: "<provider>/<model>", where the provider prefix tells Stagehand
# which API key env var to read.
#
# Default: openai/gpt-4.1-mini
# Other options include:
#   - openai/gpt-4o
#   - openai/gpt-4o-mini
#   - anthropic/claude-sonnet-4-5
#   - anthropic/claude-3-5-sonnet-20241022
BROWSER_BASE_MODEL=openai/gpt-4.1-mini

# ----------------------------------------------------------------------------
# Browser contexts
# ----------------------------------------------------------------------------

# Directory where Chrome user profiles (contexts) live.
# Each subdirectory is a context you can pass to `browser.start(<name>)`
# or `browser.useContext(<name>)`.
# Default: ./browser-context
BROWSER_BASE_CONTEXT_DIR=./browser-context

# Context to use when `browser.start()` is called without a name.
# Default: default
BROWSER_BASE_DEFAULT_CONTEXT=default

# ----------------------------------------------------------------------------
# Chrome
# ----------------------------------------------------------------------------

# Run Chrome in headful (visible) mode. Useful while developing so you
# can see what the agent is doing.
# Set to "1" to see the browser window, leave unset/0 for headless.
# Default: 0
BROWSER_BASE_HEADFUL=0

# Path to a Chrome/Chromium binary. Leave unset to auto-detect.
# Example (macOS Chromium):
# BROWSER_BASE_BROWSER_PATH=/Applications/Chromium.app/Contents/MacOS/Chromium

# Port for Chrome's remote debugging protocol.
# Default: 9222
# BROWSER_BASE_CHROME_PORT=9222

# ----------------------------------------------------------------------------
# HTTP transport (optional)
# ----------------------------------------------------------------------------

# If you want to run the MCP server over HTTP instead of stdio, set a
# port. Leave unset to use stdio.
# Default: unset (stdio)
# BROWSER_BASE_PORT=3000

# Host the HTTP server binds to.
# Default: localhost
# BROWSER_BASE_HOST=localhost

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------

# Verbosity: 0 = silent, 1 = info, 2 = debug.
# Default: 0
BROWSER_BASE_VERBOSE=0

# ----------------------------------------------------------------------------
# Common profiles (uncomment to switch)
# ----------------------------------------------------------------------------

# --- Local development (visible browser, verbose logs) ---
# BROWSER_BASE_HEADFUL=1
# BROWSER_BASE_VERBOSE=2

# --- Production / CI (headless, quiet) ---
# BROWSER_BASE_HEADFUL=0
# BROWSER_BASE_VERBOSE=0

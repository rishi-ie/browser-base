# Browser Base Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Browser Context Settings
# ============================================================================

# Directory where browser contexts (Chrome profiles) are stored
# Default: ./browser-context
BROWSER_BASE_CONTEXT_DIR=./browser-context

# Default context to use when not specified
# Default: default
BROWSER_BASE_DEFAULT_CONTEXT=default

# Run Chrome in headful (visible) mode
# Set to "1" to see the browser window, "0" for headless
# Default: 0 (headless)
BROWSER_BASE_HEADFUL=0

# Path to Chrome executable (optional, auto-detected if not set)
# Uncomment and set for custom Chrome location:
# BROWSER_BASE_BROWSER_PATH=/Applications/Chromium.app/Contents/MacOS/Chromium

# Strict mode: fail if context doesn't exist
# Set to "0" to auto-create contexts
# Default: 1 (strict)
# BROWSER_BASE_STRICT=1

# ============================================================================
# LLM Configuration (Required for act, observe, extract tools)
# ============================================================================

# OpenAI API key (required for default model)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Alternative: Use Anthropic models
# BROWSER_BASE_MODEL=anthropic/claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Model to use for LLM-powered browser automation
# Default: openai/gpt-4.1-mini
# Other options:
#   - openai/gpt-4o
#   - openai/gpt-4o-mini
#   - anthropic/claude-sonnet-4-6
#   - anthropic/claude-3-5-sonnet-20241022
BROWSER_BASE_MODEL=openai/gpt-4.1-mini

# ============================================================================
# Transport Configuration
# ============================================================================

# HTTP transport port (omit for stdio transport)
# Uncomment to use HTTP instead of stdio:
# BROWSER_BASE_PORT=3000

# HTTP host for transport
# Default: localhost
# BROWSER_BASE_HOST=localhost

# ============================================================================
# Logging
# ============================================================================

# Verbosity level (0=silent, 1=info, 2=debug)
# Default: 1
BROWSER_BASE_VERBOSE=1

# ============================================================================
# Development Settings
# ============================================================================

# Dotenv file path (default: .env in current directory)
# BROWSER_BASE_ENV_FILE=.env

# ============================================================================
# Examples for Different Use Cases
# ============================================================================

# --- Development (visible browser, verbose logging) ---
# BROWSER_BASE_HEADFUL=1
# BROWSER_BASE_VERBOSE=2

# --- Production (headless, minimal logging) ---
# BROWSER_BASE_HEADFUL=0
# BROWSER_BASE_VERBOSE=0

# --- Docker deployment ---
# BROWSER_BASE_PORT=3000
# BROWSER_BASE_HOST=0.0.0.0
# BROWSER_BASE_CONTEXT_DIR=/app/browser-context

# --- Remote MCP server ---
# BROWSER_BASE_PORT=8080
# OPENAI_API_KEY=sk-your-key
{
  "name": "browser-base",
  "version": "0.2.0",
  "description": "Simple browser control plugin for coding agents. Auto-creates contexts, login detection, deterministic operations.",
  "type": "module",
  "scripts": {
    "prepare": "npm run build",
    "build": "cd packages/core && tsc",
    "dev": "cd packages/core && tsc --watch",
    "test": "cd packages/core && vitest run"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^3.5.0",
    "playwright": "^1.49.0",
    "chrome-launcher": "^1.1.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}